generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  PRO
  UNLIMITED
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum PlanTier {
  FREE
  PRO
  UNLIMITED
}

enum MessageRole {
  user
  assistant
  system
  tool
}

enum FileType {
  PDF
  IMAGE
  DOCX
  TXT
  CSV
  XLSX
  CODE
  AUDIO
  OTHER
}

enum FileStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum ImageGenerationStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum ImageQuality {
  STANDARD
  HD
}

enum ImageStyle {
  VIVID
  NATURAL
}

enum UsageType {
  CHAT_MESSAGE
  IMAGE_GENERATION
  FILE_ANALYSIS
  VOICE_TRANSCRIPTION
  API_CALL
}

enum PromptCategory {
  WRITING
  CODING
  ANALYSIS
  CREATIVE
  BUSINESS
  EDUCATION
  RESEARCH
  CUSTOM
}

// ─── USER ────────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  emailVerifyToken String?   @unique
  image            String?
  passwordHash     String?
  role             UserRole  @default(USER)
  isActive         Boolean   @default(true)
  isBanned         Boolean   @default(false)
  banReason        String?
  lastLoginAt      DateTime?
  lastLoginIp      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  accounts         Account[]
  sessions         Session[]
  chats            Chat[]
  messages         Message[]
  files            File[]
  imageGenerations ImageGeneration[]
  subscription     Subscription?
  usageRecords     UsageRecord[]
  apiKeys          ApiKey[]
  prompts          Prompt[]
  preferences      UserPreferences?
  passwordResets   PasswordReset[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
}

// ─── NEXT-AUTH ───────────────────────────────────────────────────────────────

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ─── USER PREFERENCES ────────────────────────────────────────────────────────

model UserPreferences {
  id                  String   @id @default(cuid())
  userId              String   @unique
  defaultModel        String   @default("gpt-4o")
  defaultSystemPrompt String?  @db.Text
  temperature         Float    @default(0.7)
  maxTokens           Int      @default(2048)
  streamingEnabled    Boolean  @default(true)
  theme               String   @default("system")
  language            String   @default("en")
  fontSize            String   @default("medium")
  codeTheme           String   @default("github-dark")
  sendOnEnter         Boolean  @default(true)
  showTokenCount      Boolean  @default(true)
  enableSoundEffects  Boolean  @default(false)
  compactMode         Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── PLANS ───────────────────────────────────────────────────────────────────

model Plan {
  id                   String   @id @default(cuid())
  name                 String
  tier                 PlanTier @unique
  stripePriceIdMonthly String?  @unique
  stripePriceIdYearly  String?  @unique
  monthlyPriceUsd      Decimal  @db.Decimal(10, 2)
  yearlyPriceUsd       Decimal  @db.Decimal(10, 2)
  messagesPerDay       Int
  imagesPerDay         Int
  fileUploadsPerDay    Int
  maxFileSizeBytes     Int
  maxContextTokens     Int
  allowedModels        String[]
  features             Json
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  subscriptions        Subscription[]
}

// ─── SUBSCRIPTIONS ───────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  planId               String
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 Plan               @relation(fields: [planId], references: [id])

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([status])
}

// ─── CHATS ───────────────────────────────────────────────────────────────────

model Chat {
  id              String    @id @default(cuid())
  userId          String
  title           String    @default("New Chat")
  model           String    @default("gpt-4o")
  provider        String    @default("openai")
  systemPrompt    String?   @db.Text
  temperature     Float     @default(0.7)
  maxTokens       Int       @default(2048)
  isPinned        Boolean   @default(false)
  isArchived      Boolean   @default(false)
  shareToken      String?   @unique
  shareExpiresAt  DateTime?
  shareEnabled    Boolean   @default(false)
  totalTokensUsed Int       @default(0)
  messageCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        Message[]
  tags            ChatTag[]

  @@index([userId])
  @@index([createdAt])
  @@index([shareToken])
  @@index([isArchived])
  @@index([isPinned])
}

model ChatTag {
  id        String   @id @default(cuid())
  chatId    String
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([chatId, name])
  @@index([chatId])
}

// ─── MESSAGES ────────────────────────────────────────────────────────────────

model Message {
  id               String      @id @default(cuid())
  chatId           String
  userId           String
  role             MessageRole
  content          String      @db.Text
  reasoning        String?     @db.Text
  model            String?
  provider         String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  finishReason     String?
  durationMs       Int?
  isEdited         Boolean     @default(false)
  editedAt         DateTime?
  parentMessageId  String?
  metadata         Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?

  chat             Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments      MessageAttachment[]

  @@index([chatId])
  @@index([userId])
  @@index([createdAt])
  @@index([role])
}

model MessageAttachment {
  id         String  @id @default(cuid())
  messageId  String
  fileId     String
  displayUrl String

  message    Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  file       File    @relation(fields: [fileId], references: [id])

  @@index([messageId])
}

// ─── FILES ───────────────────────────────────────────────────────────────────

model File {
  id            String     @id @default(cuid())
  userId        String
  name          String
  originalName  String
  fileType      FileType
  mimeType      String
  sizeBytes     Int
  url           String
  key           String     @unique
  status        FileStatus @default(PROCESSING)
  extractedText String?    @db.Text
  pageCount     Int?
  dimensions    Json?
  checksum      String?
  isPublic      Boolean    @default(false)
  expiresAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments   MessageAttachment[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ─── IMAGE GENERATIONS ───────────────────────────────────────────────────────

model ImageGeneration {
  id             String                @id @default(cuid())
  userId         String
  prompt         String                @db.Text
  revisedPrompt  String?               @db.Text
  negativePrompt String?               @db.Text
  model          String                @default("dall-e-3")
  size           String                @default("1024x1024")
  quality        ImageQuality          @default(STANDARD)
  style          ImageStyle            @default(VIVID)
  status         ImageGenerationStatus @default(PENDING)
  imageUrl       String?
  thumbnailUrl   String?
  storedKey      String?               @unique
  durationMs     Int?
  errorMessage   String?
  isFavorited    Boolean               @default(false)
  isPublic       Boolean               @default(false)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deletedAt      DateTime?

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ─── USAGE TRACKING ──────────────────────────────────────────────────────────

model UsageRecord {
  id               String    @id @default(cuid())
  userId           String
  usageType        UsageType
  model            String?
  provider         String?
  promptTokens     Int       @default(0)
  completionTokens Int       @default(0)
  totalTokens      Int       @default(0)
  estimatedCostUsd Decimal   @default(0) @db.Decimal(10, 6)
  chatId           String?
  messageId        String?
  metadata         Json?
  recordedAt       DateTime  @default(now())

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([usageType])
  @@index([recordedAt])
  @@index([userId, recordedAt])
}

model DailyUsageSummary {
  id                String   @id @default(cuid())
  userId            String
  date              DateTime @db.Date
  messagesCount     Int      @default(0)
  imagesCount       Int      @default(0)
  fileAnalysisCount Int      @default(0)
  voiceMinutes      Float    @default(0)
  totalTokens       Int      @default(0)
  totalCostUsd      Decimal  @default(0) @db.Decimal(10, 4)
  updatedAt         DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ─── API KEYS ────────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  provider   String?
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  usageCount Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
}

// ─── PROMPT LIBRARY ──────────────────────────────────────────────────────────

model Prompt {
  id          String         @id @default(cuid())
  userId      String?
  title       String
  description String?
  content     String         @db.Text
  category    PromptCategory @default(CUSTOM)
  tags        String[]
  isPublic    Boolean        @default(false)
  isSystem    Boolean        @default(false)
  useCount    Int            @default(0)
  likeCount   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([category])
  @@index([isPublic])
  @@index([isSystem])
}

// ─── MODEL CONFIGS ───────────────────────────────────────────────────────────

model ModelConfig {
  id              String   @id @default(cuid())
  modelId         String   @unique
  provider        String
  displayName     String
  description     String?
  contextWindow   Int
  maxOutputTokens Int
  inputCostPer1k  Decimal  @db.Decimal(10, 6)
  outputCostPer1k Decimal  @db.Decimal(10, 6)
  supportsVision  Boolean  @default(false)
  supportsTools   Boolean  @default(false)
  supportsJson    Boolean  @default(false)
  supportsPdf     Boolean  @default(false)
  isEnabled       Boolean  @default(true)
  minPlanTier     PlanTier @default(FREE)
  sortOrder       Int      @default(0)
  capabilities    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── PLATFORM SETTINGS ───────────────────────────────────────────────────────

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("string")
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
